# MicroHarness Python — plantilla local
# Copia este archivo a .env o carga variables en tu shell.
# No guardes valores reales en este archivo.

# Opción A: reutilizar configuración local de Azurebrains + Azure Key Vault.
# scripts/load_model_from_akv.sh lee por defecto:
#   ~/.config/azurebrains/copilot-azurebrains.env
# Ese archivo debe definir solo datos locales como AZURE_KEYVAULT_NAME y, si aplica,
# AZURE_KEYVAULT_SUBSCRIPTION_ID. No se debe commitear.
export COPILOT_AZUREBRAINS_ENV_FILE="$HOME/.config/azurebrains/copilot-azurebrains.env"
export AZURE_KEYVAULT_NAME="<your-key-vault-name>"
export AZURE_KEYVAULT_SUBSCRIPTION_ID="<your-subscription-id>"

# Nombres de secretos esperados en Key Vault.
export AZURE_OPENAI_BASE_URL_SECRET_NAME="azure-openai-base-url"
export AZURE_OPENAI_MODEL_SECRET_NAME="azure-openai-model"
export AZURE_OPENAI_API_KEY_SECRET_NAME="azure-openai-api-key"
export AZURE_OPENAI_MAX_COMPLETION_TOKENS_SECRET_NAME="azure-openai-max-completion-tokens"

# Opción B: variables directas, solo local.
# Si tienes una URL completa acabada en /openai/v1, usa AZURE_OPENAI_BASE_URL.
export AZURE_OPENAI_BASE_URL="https://<resource>.openai.azure.com/openai/v1"
export AZURE_OPENAI_API_KEY="<your-api-key>"
export AZURE_OPENAI_CHAT_COMPLETION_MODEL="<your-deployment-name>"
export AZURE_OPENAI_MODEL="<your-deployment-name>"
export AZURE_OPENAI_MAX_COMPLETION_TOKENS="1024"

# Alternativa para routing Azure clásico con AzureCliCredential o api_key.
export AZURE_OPENAI_ENDPOINT="https://<resource>.openai.azure.com"
export AZURE_OPENAI_API_VERSION="2024-10-21"

# Demo
export MICROHARNESS_HOST="127.0.0.1"
export MICROHARNESS_PORT="8000"
export MICROHARNESS_REQUIRE_CONFIRMATION="false"
export AGUI_SERVER_URL="http://127.0.0.1:8000/agent"
